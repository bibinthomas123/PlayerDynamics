# =====================================================
# Players Data — IBM CIC Germany, Group 11 / 2B
# Environment Configuration
# =====================================================

# -----------------------------------------------------
# Database
# -----------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=players_data
DB_USER=postgres
DB_PASSWORD=your_password_here



# -----------------------------------------------------
# Ollama LLM API
# -----------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_S=10
OLLAMA_NLG_TIMEOUT_S=10
OLLAMA_RETRIES=3



# -----------------------------------------------------
# GPS Ingestion
# -----------------------------------------------------
GPS_SERIAL_PORT=/dev/ttyUSB0
GPS_TCP_HOST=localhost
GPS_TCP_PORT=2947


# -----------------------------------------------------
# SportRadar API
# -----------------------------------------------------
SPORTRADAR_API_KEY=your_sportradar_api_key


# -----------------------------------------------------
# Live Event WebSocket
# -----------------------------------------------------
LIVE_WS_URL=ws://localhost:8765


# -----------------------------------------------------
# MQTT Wearable Sensors
# -----------------------------------------------------
MQTT_BROKER=localhost
